generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 用户表
model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String?  @unique
  role      String   @default("submitter")
  createdAt DateTime @default(now())

  needs     Need[]
  votes     Vote[]

  @@map("users")
}

// 需求表
model Need {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  status      String   @default("待评审")
  submitterId Int
  createdAt   DateTime @default(now())

  submitter   User     @relation(fields: [submitterId], references: [id])
  votes       Vote[]

  @@map("needs")
}

// 投票表
model Vote {
  id        Int      @id @default(autoincrement())
  needId    Int
  voterId   Int
  createdAt DateTime @default(now())

  need      Need     @relation(fields: [needId], references: [id])
  voter     User     @relation(fields: [voterId], references: [id])

  @@map("votes")
}
